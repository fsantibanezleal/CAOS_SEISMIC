# ── Python ───────────────────────────────────────────────────────────────
.venv/
venv/
__pycache__/
*.py[cod]
*.egg-info/
build/
dist/
.eggs/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.ipynb_checkpoints/

# ── Secrets / local (NEVER commit; keep secrets in your own secret manager) ─
.env
*.local
*.secret

# ── Heavy data, features, model weights — NEVER versioned ──────────────────
# (rebuildable from manifests + code; see docs/data-and-pipelines.md)
data/raw/
data/clean/
data/interim/
data/mc/
data/features/
data/enrichers/
models/
checkpoints/
*.grd
*.tenv3
*.ndk
*.geojson
*.gpkg
*.parquet
*.h5
*.hdf5
*.nc
*.pt
*.safetensors
*.zst
*.npy
*.npz

# ── Node / web build ──────────────────────────────────────────────────────
app/node_modules/
app/dist/
app/.vite/
node_modules/

# ── OS / editor ───────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
*.swp

# ── Local scratch / diagnostics (process-validation only, never committed) ──
# ALL throwaway runners + their logs live under .scratch/ — keep the repo root clean.
.scratch/
.diag_*
*.log
.train*.py
.infer.log

# ── KEEP (explicitly tracked) ─────────────────────────────────────────────
# configs/, manifests/, docs/, src/, scripts/, app/src/, and the compact
# daily forecast artifacts under results/ are versioned on purpose.
!results/
!results/.gitkeep
!results/*.json
!results/*.json.gz
